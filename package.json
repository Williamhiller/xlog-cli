{
  "name": "xlog-cli",
  "version": "0.1.3",
  "description": "Local-first development logger with browser interception, file storage, and an HTML viewer.",
  "type": "module",
  "files": [
    "bin",
    "src",
    "standalone",
    "xlog-plugin.js",
    "viewer",
    "viewer-react/dist",
    "README.md",
    "README.zh-CN.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Williamhiller/xlog-cli.git"
  },
  "homepage": "https://github.com/Williamhiller/xlog-cli#readme",
  "bugs": {
    "url": "https://github.com/Williamhiller/xlog-cli/issues"
  },
  "bin": {
    "xlog-cli": "bin/xlog-cli.js",
    "xlog-mcp": "bin/xlog-mcp.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./server": "./src/server/server.js",
    "./mcp": "./src/mcp/server.js",
    "./runtime": "./src/runtime/interceptor.js",
    "./vite": "./src/plugins/vite-plugin.js",
    "./webpack": "./src/plugins/webpack-plugin.js",
    "./babel-plugin": "./src/plugins/babel-plugin.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "serve": "node ./bin/xlog-cli.js serve",
    "dev:viewer": "node ./bin/dev-viewer.js",
    "dev:viewer:ui": "vite --config viewer-react/vite.config.js",
    "build:viewer": "vite build --config viewer-react/vite.config.js",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "logger",
    "console",
    "vite",
    "webpack",
    "debug",
    "observability"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.10",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
